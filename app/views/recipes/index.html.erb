<% content_for :title, "Recipes" %>


<div class="container">
  <% if @recipes_count.zero? %>
    <h1>Sorry, we didn't find anything...</h1>
    <h2>Search again?</h2>
    <%= render('pages/search_recipes_form')%>
    <h2>Or find our most common recipes</h2>
  <% else %>
    <%= render('pages/search_recipes_form')%>
  <% end %>

  <div class="cards mt-4">
    <% @recipes.each do |recipe| %>
      <%= link_to recipe_path(recipe), class: "card-recipe" do %>
        <%= image_tag recipe.image_url, alt: recipe.title %>
        <div class="card-recipe-infos">
          <h2><%= recipe.title %></h2>
          <ul class="list-unstyled">
            <% if recipe.ratings %>
              <li><%= render_stars(recipe.ratings) %></li>
            <% end %>
            <li><i class="bi bi-stopwatch"></i> <%= recipe.formatted_prep_time %></li>
            <li><i class="bi bi-basket"></i> <%= "#{recipe.ingredients_count} items" %></li>
            <% if recipe.cuisine %>
              <li><i class="bi bi-fork-knife"></i> <%= recipe.cuisine %></li>
            <% end %>
          </ul>
        </div>
      <%end%>
    <% end %>
  </div>

  <div class="my-4 d-flex justify-content-center"><%= paginate @recipes %></div>
</div>
