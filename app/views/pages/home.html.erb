<div class="banner" style="background-image: linear-gradient(rgba(0,0,0,0.4),rgba(0,0,0,0.4)), url(https://images.unsplash.com/photo-1506368249639-73a05d6f6488?q=80&w=987&auto=format&fit=crop&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D);">
  <div class="container h-75">
    <h1 class='text-center'>Find <strong>the best recipe</strong> for <strong>anything you crave</strong>!</h1>
    <h2 class='text-white text-center'>(and what you still have in your cupboards)</h2>
    <%= form_with url: recipes_path, method: :get, local: true, class: "w-100 h-75 gap-5 d-flex align-items-center justify-content-center flex-column" do |f| %>
      <%= hw_combobox_tag :ingredient_names,
          SHARED_INGREDIENTS.map { |i| [i.capitalize, i] },
          multiple: true,
          multiselect_chip_src: chip_ingredients_path,
          free_text: true,
          input: {
            class: "form-control",
            placeholder: "Enter what's left in your kitchen"
          } %>

      <%= f.submit "Find and cook", class: "btn btn-primary rounded-pill w-75 text-wrap" %>
    <% end %>
  </div>
</div>

<div class="container my-4">
  <h1 class="text-center my-5">Find your next meal likely here</h1>
  <div class="cards">
    <% SHARED_INGREDIENTS.first(6).each do |ingredient| %>
      <%= link_to recipes_path(params: { ingredient_names: ingredient }), class:'text-center text-decoration-none' do %>
        <div class="card-category" style="background-image: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)), url('<%= asset_path("#{ingredient.parameterize}.jpg") %>')">
          <%= ingredient %>
        </div>
      <% end %>
    <% end %>
  </div>
</div>


<hr>

<div class="container my-4">
  <h1 class="text-center">Still not sure ?</h1>
  <div class="text-center d-flex justify-content-around my-4 flex-column gap-1 flex-lg-row flex-md-row">
    <%= link_to 'Browse recipes', recipes_path, class: 'btn btn-primary rounded-pill'  %>
    <%= link_to 'Browse categories', categories_path, class: 'btn btn-primary rounded-pill'  %>
  </div>
</div>
