<% content_for :title, "Recipes - #{@category.name}" %>

<div class="container">
  <%= link_to " < Back to categories list", :back, class: "btn btn-light my-4" %>
</div>

<div class="container">
  <h1><%= @category.name%></h1>
  <% if params[:ingredient_names] %>
    <%= "Search results for #{params[:ingredient_names].split(',').map(&:capitalize).join(', ')} (#{@recipes_count})"%>
  <% end %>

  <div class="container">
    <%= form_with url: category_recipes_path(@category), method: :get, local: true, class: "w-100 p-1 row gap-3 gap-lg-4 d-flex flex-column flex-lg-row align-items-center justify-content-center" do |f| %>
      <%= hw_combobox_tag :ingredient_names,
            SHARED_INGREDIENTS.map { |i| [i.capitalize, i] },
            multiple: true,
            multiselect_chip_src: chip_ingredients_path,
            free_text: true,
            input: {
              class: "form-control col-6",
              placeholder: "Enter what's left in your kitchen"
            } %>

      <%= f.submit "Find and cook", class: "btn btn-primary rounded-pill p-1 w-75 col-6" %>
    <% end %>
  </div>

  <div class="cards my-4">
    <% @recipes.each do |recipe| %>
      <%= link_to recipe_path(recipe), class: "card-recipe" do %>
        <%= image_tag recipe.image_url, alt: recipe.title %>
        <div class="card-recipe-infos">
          <h2><%= recipe.title %></h2>
          <ul class="list-unstyled">
            <% if recipe.ratings %>
              <li><%= render_stars(recipe.ratings) %></li>
            <% end %>
            <li><i class="bi bi-stopwatch"></i> <%= recipe.formatted_prep_time %></li>
            <li><i class="bi bi-basket"></i> <%= "#{recipe.ingredients_count} items" %></li>
            <% if recipe.cuisine %>
              <li><i class="bi bi-fork-knife"></i> <%= recipe.cuisine %></li>
            <% end %>
          </ul>
        </div>
      <%end%>
    <% end %>
  </div>
  <div class="d-flex justify-content-end"><%= paginate @recipes %></div>

</div>
